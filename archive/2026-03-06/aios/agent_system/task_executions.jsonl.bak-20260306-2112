        print(f\"Error: {e}\", file=sys.stderr)\n        sys.exit(1)\n    \n    except json.JSONDecodeError as e:\n        print(f\"Error: Invalid JSON in config file - {e}\", file=sys.stderr)\n        sys.exit(1)\n    \n    except Exception as e:\n        print(f\"Unexpected error: {e}\", file=sys.stderr)\n        sys.exit(1)\n\n\nif __name__ == \"__main__\":\n    main()\n</parameter>\n</invoke>\n</function_calls>\n\nNow let me create a sample config file for testing:\n\n<function_calls>\n<invoke name=\"fsWrite\">\n<parameter name=\"path\">config.json</parameter>\n<parameter name=\"content\">{\n  \"app_name\": \"MyApplication\",\n  \"version\": \"1.0.0\",\n  \"environment\": \"production\",\n  \"database\": {\n    \"host\": \"localhost\",\n    \"port\": 5432,\n    \"name\": \"mydb\",\n    \"user\": \"dbuser\"\n  },\n  \"api\": {\n    \"base_url\": \"https://api.example.com\",\n    \"timeout\": 30,\n    \"retry_attempts\": 3\n  },\n  \"logging\": {\n    \"level\": \"INFO\",\n    \"format\": \"json\",\n    \"output\": \"stdout\"\n  },\n  \"features\": {\n    \"enable_cache\": true,\n    \"enable_metrics\": true,\n    \"max_connections\": 100\n  }\n}\n</parameter>\n</invoke>\n</function_calls>\n\nLet me also create a more advanced version with additional features:\n\n<function_calls>\n<invoke name=\"fsWrite\">\n<parameter name=\"path\">config_parser.py</parameter>\n<parameter name=\"content\">#!/usr/bin/env python3\n\"\"\"\nAdvanced JSON Config Parser with validation and environment variable support\n\"\"\"\n\nimport json\nimport os\nimport re\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\n\nclass ConfigParser:\n    \"\"\"Parse and manage JSON configuration files\"\"\"\n    \n    def __init__(self, config_path: str):\n        self.config_path = Path(config_path)\n        self.config: Dict[str, Any] = {}\n        \n    def load(self) -> Dict[str, Any]:\n        \"\"\"Load and parse the configuration file\"\"\"\n        if not self.config_path.exists():\n            raise FileNotFoundError(f\"Config file not found: {self.config_path}\")\n        \n        with open(self.config_path, 'r', encoding='utf-8') as f:\n            self.config = json.load(f)\n        \n        # Process environment variables\n        self.config = self._process_env_vars(self.config)\n        \n        return self.config\n    \n    def _process_env_vars(self, obj: Any) -> Any:\n        \"\"\"\n        Recursively process environment variable placeholders\n        Supports ${ENV_VAR} and ${ENV_VAR:default_value} syntax\n        \"\"\"\n        if isinstance(obj, dict):\n            return {k: self._process_env_vars(v) for k, v in obj.items()}\n        elif isinstance(obj, list):\n            return [self._process_env_vars(item) for item in obj]\n        elif isinstance(obj, str):\n            return self._replace_env_vars(obj)\n        return obj\n    \n    def _replace_env_vars(self, value: str) -> str:\n        \"\"\"Replace environment variable placeholders in string\"\"\"\n        pattern = r'\\$\\{([^}:]+)(?::([^}]*))?\\}'\n        \n        def replacer(match):\n            var_name = match.group(1)\n            default_value = match.group(2) if match.group(2) is not None else ''\n            return os.getenv(var_name, default_value)\n        \n        return re.sub(pattern, replacer, value)\n    \n    def get(self, key: str, default: Any = None) -> Any:\n        \"\"\"Get configuration value by dot-notation key\"\"\"\n        keys = key.split('.')\n        value = self.config\n        \n        for k in keys:\n            if isinstance(value, dict) and k in value:\n                value = value[k]\n            else:\n                return default\n        \n        return value\n    \n    def validate_required(self, required_keys: list) -> bool:\n        \"\"\"Validate that required configuration keys exist\"\"\"\n        missing = []\n        \n        for key in required_keys:\n            if self.get(key) is None:\n                missing.append(key)\n        \n        if missing:\n            raise ValueError(f\"Missing required config keys: {', '.join(missing)}\")\n        \n        return True\n    \n    def to_dict(self) -> Dict[str, Any]:\n        \"\"\"Return configuration as dictionary\"\"\"\n        return self.config.copy()\n\n\n# Example usage\nif __name__ == \"__main__\":\n    import sys\n    \n    if len(sys.argv) < 2:\n        print(\"Usage: python config_parser.py <config_file.json>\")\n        sys.exit(1)\n    \n    try:\n        parser = ConfigParser(sys.argv[1])\n        config = parser.load()\n        \n        print(\"Configuration loaded successfully:\")\n        print(json.dumps(config, indent=2))\n        \n        # Example: Access nested values\n        print(\"\\nExample access:\")\n        print(f\"App name: {parser.get('app_name')}\")\n        print(f\"Database host: {parser.get('database.host')}\")\n        print(f\"Non-existent key: {parser.get('foo.bar', 'default_value')}\")\n        \n    except Exception as e:\n        print(f\"Error: {e}\", file=sys.stderr)\n        sys.exit(1)\n</parameter>\n</invoke>\n</function_calls>\n\n<function_calls>\n<invoke name=\"fsWrite\">\n<parameter name=\"path\">config_with_env.json</parameter>\n<parameter name=\"content\">{\n  \"app_name\": \"MyApplication\",\n  \"environment\": \"${APP_ENV:development}\",\n  \"database\": {\n    \"host\": \"${DB_HOST:localhost}\",\n    \"port\": 5432,\n    \"name\": \"${DB_NAME:mydb}\",\n    \"password\": \"${DB_PASSWORD}\"\n  },\n  \"api\": {\n    \"key\": \"${API_KEY}\",\n    \"base_url\": \"${API_URL:https://api.example.com}\"\n  }\n}\n</parameter>\n</invoke>\n</function_calls>\n\nNow let me create a README with usage examples:\n\n<function_calls>\n<invoke name=\"fsWrite\">\n<parameter name=\"path\">README.md</parameter>\n<parameter name=\"content\"># JSON Config Parser\n\nParse JSON configuration files with Python.\n\n## Files\n\n- `parse_config.py` - Simple JSON parser\n- `config_parser.py` - Advanced parser with environment variable support\n- `config.json` - Sample configuration file\n- `config_with_env.json` - Sample config with environment variables\n\n## Usage\n\n### Basic Parser\n\n```bash\npython parse_config.py config.json\n```\n\n### Advanced Parser\n\n```bash\npython config_parser.py config.json\n```\n\n### With Environment Variables\n\n```bash\nexport DB_HOST=prod-db.example.com\nexport API_KEY=your-api-key\npython config_parser.py config_with_env.json\n```\n\n## Features\n\n### Basic Parser\n- Simple JSON file parsing\n- Error handling for missing files and invalid JSON\n- Command-line interface\n\n### Advanced Parser\n- Environment variable substitution (`${VAR}` or `${VAR:default}`)\n- Dot-notation access to nested values\n- Required key validation\n- Recursive processing of nested structures\n\n## Python API\n\n```python\nfrom config_parser import ConfigParser\n\n# Load configuration\nparser = ConfigParser('config.json')\nconfig = parser.load()\n\n# Access values\napp_name = parser.get('app_name')\ndb_host = parser.get('database.host')\ndefault_val = parser.get('missing.key', 'default')\n\n# Validate required keys\nparser.validate_required(['app_name', 'database.host'])\n\n# Get as dictionary\nconfig_dict = parser.to_dict()\n```\n</parameter>\n</invoke>\n</function_calls>\n\nDone! I've created a complete JSON config parser solution with:\n\n1. **parse_config.py** - Simple parser for basic JSON config files\n2. **config_parser.py** - Advanced parser with environment variable support and dot-notation access\n3. **config.json** - Sample configuration file\n4. **config_with_env.json** - Config with environment variable placeholders\n5. **README.md** - Documentation and usage examples\n\nThe advanced parser supports `${ENV_VAR}` and `${ENV_VAR:default}` syntax for environment variables, making it flexible for different deployment environments.", "tokens": {"input": 5072, "output": 2277}}, "retry_count": 0, "total_attempts": 1}
