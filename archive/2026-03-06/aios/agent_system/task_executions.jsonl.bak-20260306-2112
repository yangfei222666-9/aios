esult\n\n\n# --- severity: INFO ---\n\ndef test_info_omits_alert_key():\n    result = handle_error(make_error(severity=ErrorSeverity.INFO))\n    assert \"alert\" not in result\n\n\n# --- retryable ---\n\ndef test_retryable_true_includes_retry_after():\n    result = handle_error(make_error(retryable=True))\n    assert result[\"retry_after\"] == 30\n\ndef test_retryable_false_omits_retry_after():\n    result = handle_error(make_error(retryable=False))\n    assert \"retry_after\" not in result\n\n\n# --- combinations ---\n\ndef test_critical_and_retryable():\n    result = handle_error(make_error(severity=ErrorSeverity.CRITICAL, retryable=True))\n    assert result[\"alert\"] is True\n    assert result[\"retry_after\"] == 30\n\ndef test_warning_and_not_retryable():\n    result = handle_error(make_error(severity=ErrorSeverity.WARNING, retryable=False))\n    assert result[\"alert\"] is False\n    assert \"retry_after\" not in result\n\ndef test_info_and_retryable():\n    result = handle_error(make_error(severity=ErrorSeverity.INFO, retryable=True))\n    assert \"alert\" not in result\n    assert result[\"retry_after\"] == 30\n\ndef test_full_response_shape_critical_retryable():\n    error = AppError(message=\"DB down\", code=503, severity=ErrorSeverity.CRITICAL, retryable=True)\n    result = handle_error(error)\n    assert result == {\"message\": \"DB down\", \"code\": 503, \"alert\": True, \"retry_after\": 30}\n\ndef test_full_response_shape_info_not_retryable():\n    error = AppError(message=\"FYI\", code=200, severity=ErrorSeverity.INFO, retryable=False)\n    result = handle_error(error)\n    assert result == {\"message\": \"FYI\", \"code\": 200}\n</parameter>\n</invoke>\n</function_calls>\n\nDone. Created `tests/test_error_handler.py` with 15 tests covering:\n\n- `message` and `code` always present\n- `alert: True` for CRITICAL, `alert: False` for WARNING, `alert` omitted for INFO\n- `retry_after: 30` when retryable, omitted when not\n- Key combinations (critical+retry