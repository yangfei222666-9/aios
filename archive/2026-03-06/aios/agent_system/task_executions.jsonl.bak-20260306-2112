press(backup_name, dry_run)\\n            actions.append(f\\\"Compressed -> {compressed}\\\")\\n            backup_name = compressed\\n\\n        pruned = self._prune_backups(dry_run)\\n        actions.extend(pruned)\\n\\n        return actions\\n\\n    def _compress(self, filepath: str, dry_run: bool = False) -> str:\\n        \\\"\\\"\\\"Compress a file using gz or bz2.\\\"\\\"\\\"\\n        fmt = self.config.compress_format\\n        compressed_path = f\\\"{filepath}.{fmt}\\\"\\n\\n        if not dry_run:\\n            if fmt == \\\"gz\\\":\\n                with open(filepath, \\\"rb\\\") as f_in:\\n                    with gzip.open(compressed_path, \\\"wb\\\") as f_out:\\n                        shutil.copyfileobj(f_in, f_out)\\n            elif fmt == \\\"bz2\\\":\\n                with open(filepath, \\\"rb\\\") as f_in:\\n                    with bz2.open(compressed_path, \\\"wb\\\") as f_out:\\n                        shutil.copyfileobj(f_in, f_out)\\n            os.remove(filepath)\\n\\n        return compressed_path\\n\\n    def _list_backups(self) -> List[str]:\\n        \\\"\\\"\\\"List all backup files for this log, sorted oldest first.\\\"\\\"\\\"\\n        pattern = f\\\"{self.log_path}.*\\\"\\n        backups = glob.glob(pattern)\\n        # Exclude the original log file itself\\n        backups = [b for b in backups if b != str(self.log_path)]\\n        return sorted(backups, key=os.path.getmtime)\\n\\n    def _prune_backups(self, dry_run: bool = False) -> List[str]:\\n        \\\"\\\"\\\"Remove oldest backups beyond max_backups limit.\\\"\\\"\\\"\\n        actions = []\\n        backups = self._list_backups()\\n        excess = len(backups) - self.config.max_backups\\n\\n        for backup in backups[:excess]:\\n            actions.append(f\\\"Deleted old backup: {backup}\\\")\\n            if not dry_run:\\n                os.remove(backup)\\n\\n        return actions\\n\\n    def status(self) -> dict:\\n        \\\"\\\"\\\"Return current status