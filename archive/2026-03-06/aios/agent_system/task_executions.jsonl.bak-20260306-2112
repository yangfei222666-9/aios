rhead\n    - ThreadPoolExecutor replaces per-task Thread creation\n    - Condition variable replaces busy-wait sleep loop\n    - Disabled tasks are skipped at pop time; heap stays clean via lazy deletion\n    - next_run advances from the *scheduled* time, not wall-clock after execution,\n      preventing interval drift\n    - list_tasks no longer calls get_task_info under the same lock (avoids re-entrant lock)\n    \"\"\"\n\n    def __init__(self, max_workers: int = 8) -> None:\n        self._heap: List[Task] = []          # min-heap, guarded by _lock\n        self._tasks: Dict[str, Task] = {}    # name → Task, guarded by _lock\n        self._lock = threading.Lock()\n        self._cond = threading.Condition(self._lock)\n        self._running = False\n        self._thread: Optional[threading.Thread] = None\n        self._pool = ThreadPoolExecutor(max_workers=max_workers,\n                                        thread_name_prefix=\"sched-worker\")\n\n    # ------------------------------------------------------------------\n    # Public API\n    # ------------------------------------------------------------------\n\n    def add_task(self, name: str, func: Callable, interval: float,\n                 args: tuple = (), kwargs: Optional[dict] = None,\n                 enabled: bool = True) -> None:\n        with self._cond:\n            if name in self._tasks:\n                logger.warning(\"Task '%s' already exists, skipping.\", name)\n                return\n            task = Task(name, func, interval, args, kwargs, enabled)\n            self._tasks[name] = task\n            if enabled:\n                heapq.heappush(self._heap, task)\n                self._cond.notify()\n            logger.info(\"Task '%s' added (interval=%.2fs).\", name, interval)\n\n    def remove_task(self, name: str) -> bool:\n        with self._cond:\n            task = self._tasks.pop(name, None)\n            if task is None:\n                logger.warning(\"Task '%s' not found.\", name)\n 