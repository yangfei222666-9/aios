(item.dt * 1000),\n      temperature: item.main.temp,\n      description: item.weather[0].description,\n      humidity: item.main.humidity,\n      windSpeed: item.wind.speed\n    }));\n  } catch (error) {\n    console.error('Error fetching forecast data:', error);\n    throw error;\n  }\n}\n\n// Example usage\nasync function main() {\n  try {\n    const weather = await getCurrentWeather('London');\n    console.log('Current Weather:', weather);\n    \n    const forecast = await getForecast('London');\n    console.log('5-Day Forecast:', forecast.slice(0, 5));\n  } catch (error) {\n    console.error('Failed to fetch weather data:', error.message);\n  }\n}\n\nmodule.exports = { getCurrentWeather, getForecast };\n```\n\nHere's also a Python version if you prefer:\n\n```python\n# weather_api.py\nimport requests\nfrom typing import Dict, List\nfrom datetime import datetime\n\nWEATHER_API_KEY = 'YOUR_API_KEY_HERE'  # Replace with your actual API key\nBASE_URL = 'https://api.openweathermap.org/data/2.5'\n\ndef get_current_weather(city: str) -> Dict:\n    \"\"\"\n    Fetches current weather data for a given city\n    \"\"\"\n    try:\n        response = requests.get(\n            f'{BASE_URL}/weather',\n            params={\n                'q': city,\n                'appid': WEATHER_API_KEY,\n                'units': 'metric'\n            }\n        )\n        response.raise_for_status()\n        data = response.json()\n        \n        return {\n            'city': data['name'],\n            'country': data['sys']['country'],\n            'temperature': data['main']['temp'],\n            'feels_like': data['main']['feels_like'],\n            'humidity': data['main']['humidity'],\n            'description': data['weather'][0]['description'],\n            'wind_speed': data['wind']['speed'],\n            'icon': data['weather'][0]['icon']\n        }\n    except requests.exceptions.RequestException as e:\n        print(f'Error fetching weather data: {e}')\n        raise\n\ndef get_forecast(city: str) -> List[Dict]:\n    \"\"\"\n    Fetches 5-day weather forecast\n    \"\"\"\n    try:\n        response = requests.get(\n            f'{BASE_URL}/forecast',\n            params={\n                'q': city,\n                'appid': WEATHER_API_KEY,\n                'units': 'metric'\n            }\n        )\n        response.raise_for_status()\n        data = response.json()\n        \n        return [\n            {\n                'date': datetime.fromtimestamp(item['dt']),\n                'temperature': item['main']['temp'],\n                'description': item['weather'][0]['description'],\n                'humidity': item['main']['humidity'],\n                'wind_speed': item['wind']['speed']\n            }\n            for item in data['list']\n        ]\n    except requests.exceptions.RequestException as e:\n        print(f'Error fetching forecast data: {e}')\n        raise\n\nif __name__ == '__main__':\n    try:\n        weather = get_current_weather('London')\n        print('Current Weather:', weather)\n        \n        forecast = get_forecast('London')\n        print('5-Day Forecast:', forecast[:5])\n    except Exception as e:\n        print(f'Failed to fetch weather data: {e}')\n```\n\n**Setup Instructions:**\n\n1. Sign up for a free API key at [OpenWeatherMap](https://openweathermap.org/api)\n2. Replace `YOUR_API_KEY_HERE` with your actual API key\n3. For Python, install requests: `pip install requests`\n4. For Node.js, use built-in fetch (Node 18+) or install node-fetch for older versions\n\nThe implementation includes current weather and 5-day forecast fetching with proper error handling and clean data formatting.", "tokens": {"input": 3629, "output": 1317}}, "retry_count": 0, "total_attempts": 1}
