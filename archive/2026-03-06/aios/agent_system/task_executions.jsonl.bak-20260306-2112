      else:\n            recovery = \"unknown\"\n        \n        result = {\n            \"success\": False,\n            \"agent\": self.name,\n            \"error\": error_message,\n            \"error_type\": error_type,\n            \"recovery\": recovery,\n            \"context\": context,\n        }\n        \n        self.memory.append(result)\n        return result\n\n    async def execute_with_retry(self, task: dict) -> dict:\n        \"\"\"Execute a task with automatic retry logic.\"\"\"\n        last_error = None\n        \n        for attempt in range(self.max_retries):\n            try:\n                result = await self._execute_task(task)\n                return result\n            except Exception as e:\n                last_error = e\n                logger.warning(f\"Attempt {attempt + 1} failed: {e}\")\n                if attempt < self.max_retries - 1:\n                    await asyncio.sleep(self.retry_delay)\n        \n        return self.handle_error(last_error, context={\"task\": task, \"attempts\": self.max_retries})\n\n    async def _execute_task(self, task: dict) -> dict:\n        \"\"\"Internal task execution.\"\"\"\n        task_type = task.get(\"type\")\n        \n        if task_type == \"skill_creation\":\n            return await self._create_skill(task)\n        elif task_type == \"document_processing\":\n            return await self._process_document(task)\n        else:\n            raise ValueError(f\"Unknown task type: {task_type}\")\n\n    async def _create_skill(self, task: dict) -> dict:\n        \"\"\"Simulate skill creation.\"\"\"\n        await asyncio.sleep(0.1)\n        if task.get(\"simulate_failure\"):\n            raise AgentError(\"Simulated failure\")\n        return {\"success\": True, \"agent\": self.name, \"skill\": task.get(\"name\")}\n\n    async def _process_document(self, task: dict) -> dict:\n        \"\"\"Simulate document processing.\"\"\"\n        await asyncio.sleep(0.1)\n        if task.get(\"simulate_failure\"):\n            raise ConnectionError(\"Simulated failure\")\n        return {\"success\": True, \"agent\": self.name, \"document\": task.get(\"name\")}\n\n    def add_to_memory(self, entry: dict) -> None:\n        \"\"\"Add an entry to agent memory.\"\"\"\n        self.memory.append(entry)\n\n    def get_memory(self) -> list:\n        \"\"\"Get all memory entries.\"\"\"\n        return self.memory.copy()\n\n    def register_skill(self, name: str, handler) -> None:\n        \"\"\"Register a skill handler.\"\"\"\n        self.skills[name] = handler\n\n    def get_skill(self, name: str):\n        \"\"\"Get a registered skill handler.\"\"\"\n        return self.skills.get(name)\n```\n\n</content>\n</kiro-read-code>\n</kiro-tool-calls>\n\n<kiro-tool-calls>\n<kiro-fs-write>\n<path>test_handle_error.py</path>\n<content>import pytest\nfrom agent import Agent, AgentError\n\n\n@pytest.fixture\ndef agent():\n    return Agent(name=\"tester\", max_retries=3, retry_delay=0.1)\n\n\nclass TestHandleErrorReturnStructure:\n    def test_returns_dict_with_required_keys(self, agent):\n        result = agent.handle_error(ValueError(\"bad input\"))\n        assert {\"success\", \"agent\", \"error\", \"error_type\", \"recovery\", \"context\"} <= result.keys()\n\n    def test_success_is_false(self, agent):\n        result = agent.handle_error(RuntimeError(\"oops\"))\n        assert result[\"success\"] is False\n\n    def test_agent_name_matches(self, agent):\n        result = agent.handle_error(RuntimeError(\"oops\"))\n        assert result[\"agent\"] == \"tester\"\n\n    def test_error_message_captured(self, agent):\n        result = agent.handle_error(ValueError(\"bad input\"))\n        assert result[\"error\"] == \"bad input\"\n\n    def test_error_type_captured(self, agent):\n        result = agent.handle_error(ValueError(\"bad input\"))\n        assert result[\"error_type\"] == \"ValueError\"\n\n\nclass TestHandleErrorRecoveryActions:\n    def test_connection_error_returns_retry(self, agent):\n        result = agent.handle_error(ConnectionError(\"timeout\"))\n        assert result[\"recovery\"] == \"retry\"\n\n    def test_value_error_returns_skip(self, agent):\n        result = agent.handle_error(ValueError(\"invalid\"))\n        assert result[\"recovery\"] == \"skip\"\n\n    def test_agent_error_returns_abort(self, agent):\n        result = agent.handle_error(AgentError(\"fatal\"))\n        assert result[\"recovery\"] == \"abort\"\n\n    def test_unknown_error_returns_unknown(self, agent):\n        result = agent.handle_error(RuntimeError(\"unexpected\"))\n        assert result[\"recovery\"] == \"unknown\"\n\n    def test_key_error_returns_unknown(self, agent):\n        result = agent.handle_error(KeyError(\"missing_key\"))\n        assert result[\"recovery\"] == \"unknown\"\n\n\nclass TestHandleErrorContext:\n    def test_default_context_is_empty_dict(self, agent):\n        result = agent.handle_error(RuntimeError(\"err\"))\n        assert result[\"context\"] == {}\n\n    def test_provided_context_is_stored(self, agent):\n        ctx = {\"task\": \"process\", \"attempts\": 2}\n        result = agent.handle_error(RuntimeError(\"err\"), context=ctx)\n        assert result[\"context\"] == ctx\n\n    def test_none_context_defaults_to_empty_dict(self, agent):\n        result = agent.handle_error(RuntimeError(\"err\"), context=None)\n        assert result[\"context\"] == {}\n\n\nclass TestHandleErrorMemory:\n    def test_error_appended_to_memory(self, agent):\n        agent.handle_error(ValueError(\"bad\"))\n        assert len(agent.memory) == 1\n\n    def test_multiple_errors_all_appended(self, agent):\n        agent.handle_error(ValueError(\"first\"))\n        agent.handle_error(ConnectionError(\"second\"))\n        assert len(agent.memory) == 2\n\n    def test_memory_entry_matches_returned_result(self, agent):\n        result = agent.handle_error(AgentError(\"fatal\"))\n        assert agent.memory[-1] == result\n\n    def test_memor